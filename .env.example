# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# From Meta Developer Console → App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=          # Numeric ID of your sender phone number
WHATSAPP_ACCESS_TOKEN=             # Permanent system-user token (not temp token)
WHATSAPP_VERIFY_TOKEN=             # Arbitrary string you set in webhook config
WHATSAPP_APP_SECRET=               # App Secret from Meta App Settings → Basic

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # sk-ant-...

# ─── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=                 # rediss://:<password>@<host>:<port>
# BullMQ also uses the same Redis connection
REDIS_HOST=                        # host only, extracted for BullMQ IORedis opts
REDIS_PORT=                        # e.g. 6380
REDIS_PASSWORD=                    # same password as in UPSTASH_REDIS_URL

# ─── Supabase ─────────────────────────────────────────────────────────────────
# M2 will confirm — do NOT hardcode table names yet
SUPABASE_URL=                      # https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # Service role key (backend only — never expose)

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=               # Geocoding API enabled

# ─── AES-256 Encryption ───────────────────────────────────────────────────────
ENCRYPTION_KEY=                    # 64 hex chars = 32 bytes (generate once: openssl rand -hex 32)
ENCRYPTION_IV_LENGTH=16            # Fixed — do not change after first deploy

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development               # development | production
SUPABASE_ANON_KEY=
DATABASE_URL=
WHATSAPP_BUSINESS_ACCOUNT_ID=